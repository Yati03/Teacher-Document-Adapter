# Copy this file to .env.local and replace every placeholder locally.
# Never commit .env.local.
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority"
MONGODB_DB="teacher-document-adapter"

# Generate a long random value, for example: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Required for the OpenAI Agents SDK document-adaptation workflow.
OPENAI_API_KEY=""
# Optional. The app defaults to gpt-5.6-terra.
OPENAI_MODEL="gpt-5.6-terra"
